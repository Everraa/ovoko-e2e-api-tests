{
  "name": "ovoko",
  "version": "1.0.0",
  "private": true,
  "description": "Playwright E2E and API automation",
  "scripts": {
    "test": "playwright test",
    "test:api": "playwright test --project=api",
    "test:api:report": "playwright test --project=api && playwright show-report",
    "test:chromium": "playwright test --project=chromium --workers=1",
    "test:firefox": "playwright test --project=firefox --workers=1",
    "test:browsers": "playwright test --project=chromium --project=firefox --workers=1",
    "test:browsers:report": "playwright test --project=chromium --project=firefox --workers=1 && playwright show-report",
    "test:local": "playwright test --workers=1",
    "test:local:chromium": "playwright test --project=chromium --workers=1",
    "test:local:firefox": "playwright test --project=firefox --workers=1",
    "test:local:webkit": "playwright test --project=webkit --workers=1",
    "test:local:report": "playwright test --project=chromium --workers=1 && playwright show-report",
    "test:report": "playwright show-report",
    "test:ui": "playwright test --ui",
    "codegen": "playwright codegen",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@faker-js/faker": "^9.9.0",
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.1.0",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.7.4",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.50.0"
  }
}
